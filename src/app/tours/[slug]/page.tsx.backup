import { notFound } from 'next/navigation';
import { tours } from '@/data/tours';
import Image from 'next/image';
import { CheckCircle2 } from 'lucide-react';

export function generateStaticParams() {
  return tours.map((tour) => ({ slug: tour.slug }));
}

export default async function TourPage({ params }: { params: Promise<{ slug: string }> }) {
  const { slug } = await params;
  const tour = tours.find((t) => t.slug === slug);

  if (!tour) notFound();

  return (
    <main className="bg-white min-h-screen">
      <section className="relative min-h-[80vh] bg-gradient-to-br from-sky-400 via-cyan-500 to-blue-500 text-white pt-32 pb-20">
        <div className="max-w-7xl mx-auto px-6">
          <div className="max-w-3xl">
            <h1 className="text-6xl lg:text-7xl font-black mb-6 leading-tight">{tour.title}</h1>
            <p className="text-xl mb-8 leading-relaxed">{tour.description}</p>

            <div className="flex gap-4 flex-wrap mb-8">
              <div className="bg-white/20 backdrop-blur-md px-6 py-3 rounded-full">Up to {tour.maxGuests} guests</div>
              <div className="bg-white/20 backdrop-blur-md px-6 py-3 rounded-full">Half & Full Day</div>
              <div className="bg-white/20 backdrop-blur-md px-6 py-3 rounded-full">Private Charter</div>
            </div>

            <a
              href="/checkout"
              className="inline-block px-12 py-5 bg-gradient-to-r from-amber-400 to-orange-500 text-white font-black text-lg rounded-full shadow-2xl hover:scale-105 transition-all"
            >
              Book This Adventure
            </a>
          </div>
        </div>
      </section>

      <section className="py-20 px-6 bg-gradient-to-b from-white to-gray-50">
        <div className="max-w-7xl mx-auto">
          <h2 className="text-5xl font-black mb-4 text-center text-gray-900">Pick the moments you&#39;ll talk about forever.</h2>
          <p className="text-center text-gray-600 mb-16 max-w-3xl mx-auto text-lg">
            Every adventure is custom. Choose activities that match your crew&#39;s energy.
          </p>

          <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {[1, 2, 3, 4, 5, 6].map((i) => (
              <div key={i} className="group relative h-96 rounded-3xl overflow-hidden shadow-2xl">
                <Image
                  src={tour.imageUrl}
                  alt={`Activity ${i}`}
                  fill
                  className="object-cover group-hover:scale-110 transition-transform duration-700"
                  sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
                />
                <div className="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent flex flex-col justify-end p-8">
                  <h3 className="text-white text-3xl font-black mb-3">Activity {i}</h3>
                  <p className="text-white/90 text-sm">Experience description here</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section className="py-20 px-6 bg-white">
        <div className="max-w-6xl mx-auto">
          <h2 className="text-5xl font-black mb-16 text-center text-gray-900">
            Pick 1. Pick all 10.<br />It&#39;s your call.
          </h2>

          <div className="grid md:grid-cols-3 gap-12">
            <div className="text-center p-8 bg-gray-50 rounded-3xl">
              <div className="w-20 h-20 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 text-white flex items-center justify-center text-3xl font-black mx-auto mb-6">
                1
              </div>
              <h3 className="text-2xl font-black mb-4 text-gray-900">Start Talking</h3>
              <p className="text-gray-600 leading-relaxed">
                Meet the crew & set priorities. Reef? Fishing? Food? We align the day to your vibe.
              </p>
            </div>

            <div className="text-center p-8 bg-gray-50 rounded-3xl">
              <div className="w-20 h-20 rounded-full bg-gradient-to-br from-cyan-400 to-blue-500 text-white flex items-center justify-center text-3xl font-black mx-auto mb-6">
                2
              </div>
              <h3 className="text-2xl font-black mb-4 text-gray-900">Go Epic</h3>
              <p className="text-gray-600 leading-relaxed">Hit your bucket-list moments. Action blocks + iconic Belize scenes.</p>
            </div>

            <div className="text-center p-8 bg-gray-50 rounded-3xl">
              <div className="w-20 h-20 rounded-full bg-gradient-to-br from-pink-400 to-rose-500 text-white flex items-center justify-center text-3xl font-black mx-auto mb-6">
                3
              </div>
              <h3 className="text-2xl font-black mb-4 text-gray-900">Wind Down</h3>
              <p className="text-gray-600 leading-relaxed">Sunset swims, secret beaches. The last hour is always unscripted.</p>
            </div>
          </div>
        </div>
      </section>

      <section className="py-20 px-6 bg-gradient-to-b from-gray-50 to-white">
        <div className="max-w-6xl mx-auto">
          <h2 className="text-5xl font-black mb-16 text-center text-gray-900">Show up ready. Leave with stories.</h2>

          <div className="grid md:grid-cols-2 gap-16">
            <div>
              <h3 className="text-3xl font-black mb-8 text-orange-600">What&#39;s Included</h3>
              <ul className="space-y-4">
                {tour.features.map((feature, i) => (
                  <li key={i} className="flex items-start gap-4">
                    <CheckCircle2 className="w-6 h-6 text-green-500 flex-shrink-0 mt-1" />
                    <span className="text-gray-700 text-lg">{feature}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div>
              <h3 className="text-3xl font-black mb-8 text-blue-600">What to Bring</h3>
              <ul className="space-y-4 text-gray-700 text-lg">
                <li className="flex items-start gap-4">
                  <span className="text-3xl">&#x1F6E4;</span>
                  <span>Reef-safe sunscreen</span>
                </li>
                <li className="flex items-start gap-4">
                  <span className="text-3xl">&#x1F3CA;</span>
                  <span>Swimwear & towel</span>
                </li>
                <li className="flex items-start gap-4">
                  <span className="text-3xl">&#x1F576;</span>
                  <span>Polarized sunglasses</span>
                </li>
                <li className="flex items-start gap-4">
                  <span className="text-3xl">&#x1F4F7;</span>
                  <span>Waterproof camera</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section className="py-20 px-6 bg-gradient-to-br from-orange-50 to-amber-50">
        <div className="max-w-4xl mx-auto text-center">
          <h2 className="text-6xl font-black mb-8 text-gray-900">Book fast. Or go massive.</h2>
          <p className="text-2xl text-gray-700 mb-12">
            From <span className="text-5xl font-black text-orange-600">${tour.price}</span>
          </p>

          <a
            href="/checkout"
            className="inline-block px-16 py-6 bg-gradient-to-r from-amber-400 to-orange-500 text-white font-black text-xl rounded-full shadow-2xl hover:scale-105 transition-all"
          >
            Book This Adventure
          </a>

          <p className="text-gray-600 mt-8">
            Base rate includes {tour.includedGuests} guests • Extra guests ${tour.additionalGuestPrice}/person
          </p>
        </div>
      </section>
    </main>
  );
}
